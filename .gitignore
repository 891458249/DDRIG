# ============================================================
# DDRIG .gitignore
# ============================================================

# === Workspace tooling (not part of DDRIG source) ===
.claude/
.remember/

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.eggs/
build/
dist/
wheels/
pip-log.txt

# === Virtual environments ===
.venv/
venv/
env/
ENV/

# === Testing / linting caches ===
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
coverage.xml
htmlcov/

# === IDE / Editor ===
.idea/
.vscode/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db
desktop.ini

# === Maya artifacts ===
incrementalSave/
*.ma.swatches/
*.mb.swatches/

# === Logs / temp ===
*.log
*.tmp
*.bak
*.orig

# === Large third-party binaries (fetch separately if needed) ===
python/ddrig/tools/face_mocap/ffmpeg.exe
python/ddrig/utils/dembones/Linux/
python/ddrig/utils/dembones/MacOS/
python/ddrig/utils/dembones/Windows/

# === Maya sample scenes and assets (kept external to repo) ===
samples/

# === Sphinx generated documentation (regenerate via `sphinx-build` or `make html`) ===
docs/source/_build/
